# =========================
# Secrets / Environment
# =========================

# Real environment files
.env
.env.*
!.env.example

# API key / secret files
secrets.*
*.secret
*.key
*.pem
*.credentials
credentials.json
service-account*.json

# Streamlit secrets
.streamlit/secrets.toml

*.egg-info/
src/*.egg-info/

# =========================
# Project data / NDA files
# =========================

# Raw RFP data is under NDA. Do not commit original data.
data/raw/
data/**/raw/

# Versioned data folders
data/v1/raw/
data/v2/raw/
data/v3/raw/

# RFP original documents
*.pdf
*.hwp
*.hwpx
*.doc
*.docx

# Large / private metadata files
data/**/*.csv
data/**/*.xlsx
data/**/*.xls
data/**/*.json
data/**/*.jsonl
data/**/*.zip

# Allow only safe example files
!data/**/README.md
!data/**/*.example.csv
!data/**/*.example.json
!data/**/*.example.jsonl
!data/v2/eval_questions.example.jsonl


# =========================
# Processed chunks / embeddings
# =========================

# Chunked documents may contain original text, so do not commit.
data/processed/
data/**/processed/
file/
venv/

# Vector DB / embedding outputs
data/vector_store/
data/**/vector_store/
vector_store/
faiss_index/

# Common vector DB / index files
*.faiss
*.index
*.ann
*.hnsw
*.sqlite
*.sqlite3
*.db
*.duckdb
*.parquet
*.pkl
*.pickle
*.npy
*.npz


# =========================
# Model / experiment outputs
# =========================

checkpoints/
outputs/
runs/
wandb/
mlruns/
logs/


# =========================
# Python / local caches
# =========================

__pycache__/
*.py[cod]
.cache/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.venv/
venv/

